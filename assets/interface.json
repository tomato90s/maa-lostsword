{
    "interface_version": 2,
    "name": "maa-lostsword",
    "title": "MAA-LostSword - Lost Sword 自动化助手 v0.1.22",
    "icon": "logo.webp",
    "description": "Lost Sword 自动化助手，基于 MaaFramework",
    "version": "v0.1.22",
    "contact": "游戏交流 QQ 群: 1020907837",
    "welcome": "欢迎使用 MAA-LostSword！请确保模拟器打开adb调试并且分辨率为 1280x720 或 1920x1080。正在完善功能中,如遇到任何问题, 请提issue 或者加入交流群反馈！",
    "github": "https://github.com/tomato90s/maa-lostsword",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "韩服",
            "path": [
                "./resource"
            ]
        }
    ],
    "task": [],
    "group": [
        {
            "name": "system",
            "label": "系统"
        },
        {
            "name": "daily",
            "label": "日常任务"
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "option": {},
    "import": [
        "resource/tasks/system/startup_task.json",
        "resource/tasks/daily/arena_task.json",
        "resource/tasks/daily/draw_task.json",
        "resource/tasks/daily/guild_task.json",
        "resource/tasks/daily/instance_task.json",
        "resource/tasks/daily/quest_task.json",
        "resource/tasks/daily/raid_task.json",
        // "resource/tasks/daily/shop_task.json", // 暂时不需要商店日常
        "resource/tasks/daily/stonehenge_task.json",
        "resource/tasks/daily/treasure_task.json"
    ]
}